{
    "name": "pulsesync-asar",
    "version": "1.29.2",
    "description": "Mod for Yandex Music Desktop",
    "main": "index.js",
    "scripts": {
        "release": "node toolset.js release",
        "buildMod": "node toolset.js build -d",
        "buildModProd": "node toolset.js build -m --modernize",
        "rebuildMod": "node toolset.js rebuild",
        "buildModTest": "node toolset.js build -m -d",
        "buildMin": "node toolset.js build -d -m",
        "downloadLatest": "node toolset.js download",
        "migrateReport": "node toolset.js migrate-report",
        "migrateTodo": "node toolset.js migrate-todo",
        "test": "echo \"Error: no test specified\" && exit 1",
        "onUpdate": "node toolset.js extract && node toolset.js pretty && node toolset.js adaptive-patch --version=latest && node toolset.js rebuild --src=\"extracted\\latest@pretty\"",
        "onUpdate:noAP": "node toolset.js extract && node toolset.js pretty && node toolset.js rebuild --src=\"extracted\\latest@pretty\""
    },
    "author": "PulseSync <contact@pulsesync.dev>",
    "license": "GPL-3.0+",
    "dependencies": {
        "7zip-min": "^3.0.1",
        "@babel/generator": "^7.29.7",
        "@babel/parser": "^7.29.7",
        "@babel/traverse": "^7.29.7",
        "@babel/types": "^7.29.7",
        "@electron/asar": "^4.2.0",
        "@octokit/rest": "^22.0.1",
        "@types/node": "^25.9.1",
        "axios": "^1.16.1",
        "chalk": "^5.6.2",
        "dotenv": "^17.4.2",
        "electron": "^39.2.7",
        "fast-glob": "^3.3.3",
        "form-data": "^4.0.5",
        "glob": "^13.0.6",
        "js-yaml": "^4.1.1",
        "listr2": "^10.2.1",
        "minimist": "^1.2.8",
        "multicast-dns": "^7.2.5",
        "node-gyp": "^12.3.0",
        "plist": "^5.0.0",
        "prettier": "^3.8.3",
        "readline-sync": "^1.4.10",
        "semver": "^7.8.1",
        "terser": "^5.48.0",
        "ws": "^8.21.0",
        "zstd-codec": "^0.1.5"
    }
}
